# Server
PORT=3001
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/cabroute

# Python Flask optimizer service
FLASK_SERVICE_URL=http://localhost:5001

# File upload limits
MAX_FILE_SIZE_MB=10

# Default optimization config
DEFAULT_CAB_CAPACITY=6
DEFAULT_RATE_PER_KM=18
DEFAULT_WORKING_DAYS=26
DEFAULT_OFFICE_LAT=12.9352
DEFAULT_OFFICE_LNG=77.6245